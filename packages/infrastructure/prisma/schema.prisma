generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  products    Product[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id           String    @id @default(cuid())
  code         String    @unique
  name         String
  description  String?
  imagePath    String?
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])
  price        Float
  premiumPrice Float
  detailPrice  Float?
  cost         Float
  stock        Int       @default(0)
  /// Orden manual (fraccionario, no secuencial): reordenar un producto solo
  /// reescribe su propio valor (promedio entre vecinos), nunca el resto.
  order        Float     @default(0)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Settings {
  id            Int     @id @default(1)
  companyName   String  @default("")
  logo          String?
  address       String?
  city          String?
  phone         String?
  whatsapp      String?
  email         String?
  website       String?
  facebook      String?
  instagram     String?
  primaryColor  String  @default("#E5141F")
  secondaryColor String @default("#0A0A0B")
}
