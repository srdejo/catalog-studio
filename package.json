{
  "name": "catalog-studio",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @catalog-studio/desktop",
    "build": "npm run build -w @catalog-studio/desktop",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:generate": "npm run db:generate -w @catalog-studio/infrastructure",
    "db:migrate": "npm run db:migrate -w @catalog-studio/infrastructure",
    "db:studio": "npm run db:studio -w @catalog-studio/infrastructure"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
